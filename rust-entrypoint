#!/usr/bin/env bash

set -xeuo pipefail

export DEBIAN_FRONTEND=noninteractive

HELPER_TOOLS_REPO=${HELPER_TOOLS_REPO:-https://raw.githubusercontent.com/leynos/agent-helper-scripts/refs/heads/main}

function ensure_profile_path()
{
  local line=$1
  local file

  for file in "${HOME}/.bashrc" "${HOME}/.bash_profile"; do
    touch "${file}"
    if ! grep -Fqx "${line}" "${file}"; then
      echo "${line}" >> "${file}"
    fi
  done
}

ensure_profile_path "PATH=\$HOME/.local/bin:\$PATH"
ensure_profile_path "PATH=\$HOME/.cargo/bin:\$PATH"
ensure_profile_path "PATH=\$HOME/.bun/bin:\$PATH"

export PATH="${HOME}/.bun/bin:${HOME}/.cargo/bin:${HOME}/.local/bin:${PATH}"

function needs()
{
  ! which "$1" >/dev/null 2>/dev/null
}

if needs uv; then
  curl -LsSf https://astral.sh/uv/install.sh | sh
  if [[ -f "$HOME/.local/bin/env" ]]; then
    # shellcheck source=/dev/null
    source "$HOME/.local/bin/env"
  fi
fi

if needs bun; then
  curl -fsSL https://bun.sh/install | bash
fi

export PATH="${HOME}/.bun/bin:${PATH}"

if needs rustup; then
  curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
fi

if needs sudo; then
  # Fingers crossed this works. Assuming that systems without sudo will be running as root
  echo "export DEBIAN_FRONTEND=noninteractive" >> /root/.profile
  apt-get update -y
  apt-get install -y apt-utils
  apt-get install -y sudo
fi

if [[ -d "/usr/local/rustup" ]]; then
  sudo chmod -R go=u "/usr/local/rustup"
fi

if needs wget; then
  sudo DEBIAN_FRONTEND=noninteractive apt-get update -y
  sudo DEBIAN_FRONTEND=noninteractive apt-get install -y apt-utils
  sudo DEBIAN_FRONTEND=noninteractive apt-get install -y wget
fi

for tool in \
  get-markdown-tooling \
  get-rust-tooling \
  rust-setup \
  get-github-tooling \
  install-skills \
  install-hooks; do
    echo "Running $tool..."
    curl -fsSL "${HELPER_TOOLS_REPO}/$tool" | bash -i -xeuo pipefail
done
