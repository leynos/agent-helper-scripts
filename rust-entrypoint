#!/usr/bin/env bash

# Compatibility wrapper for the split Rust bootstrap entrypoints.
# RUST_ENTRYPOINT_PHASE selects the authority boundary to run: system, home,
# or both. The default preserves the historical one-shot bootstrap behaviour.

set -euo pipefail
if [[ "${WITH_TRACE:-0}" =~ ^(1|true|TRUE|yes|YES|on|ON)$ ]]; then
  set -x
fi

HELPER_TOOLS_REPO_URL=${HELPER_TOOLS_REPO_URL:-https://github.com/leynos/agent-helper-scripts.git}
HELPER_TOOLS_REPO_BRANCH=${HELPER_TOOLS_REPO_BRANCH:-main}
HELPER_TOOLS_REPO_NAME=${HELPER_TOOLS_REPO_URL##*/}
HELPER_TOOLS_REPO_NAME=${HELPER_TOOLS_REPO_NAME%.git}
HELPER_TOOLS_REPO_DIR=${HELPER_TOOLS_REPO_DIR:-${HOME}/git/${HELPER_TOOLS_REPO_NAME}}
export HELPER_TOOLS_REPO_DIR
export HELPER_TOOLS_REPO_BRANCH
RUST_ENTRYPOINT_PHASE=${RUST_ENTRYPOINT_PHASE:-both}
case "${RUST_ENTRYPOINT_PHASE}" in
  system|home|both)
    ;;
  *)
    echo "Unknown RUST_ENTRYPOINT_PHASE: ${RUST_ENTRYPOINT_PHASE}" >&2
    exit 2
    ;;
esac

# Purpose:
#   Resolve the directory containing this wrapper when it was executed from a
#   file path.
# Parameters:
#   None.
# Returns:
#   Prints the wrapper directory, or an empty string when the wrapper is being
#   executed from stdin.
# Side effects:
#   Reads BASH_SOURCE.
function local_script_dir()
{
  local source_path=${BASH_SOURCE[0]:-}

  if [[ -z "${source_path}" || ! -e "${source_path}" ]]; then
    printf ''
    return 0
  fi

  cd -- "$(dirname -- "${source_path}")" && pwd
}

# Purpose:
#   Clone or update the managed helper repository checkout.
# Parameters:
#   None.
# Returns:
#   0 when the managed helper checkout is ready.
# Side effects:
#   Runs git clone, fetch, and reset. Sets SCRIPT_DIR to HELPER_TOOLS_REPO_DIR.
function clone_or_update_delegate_repo()
{
  local git_is_work_tree

  if ! command -v git >/dev/null 2>&1; then
    printf 'Error: git is required to clone split bootstrap entrypoints.\n' >&2
    exit 1
  fi

  if [[ -e "${HELPER_TOOLS_REPO_DIR}" ]]; then
    if git_is_work_tree=$(git -C "${HELPER_TOOLS_REPO_DIR}" rev-parse --is-inside-work-tree 2>/dev/null) \
      && [[ "${git_is_work_tree}" == true ]]; then
      git -C "${HELPER_TOOLS_REPO_DIR}" fetch --depth 1 origin "${HELPER_TOOLS_REPO_BRANCH}"
      git -C "${HELPER_TOOLS_REPO_DIR}" reset --hard FETCH_HEAD
    else
      printf 'Error: %s exists but is not a git checkout\n' "${HELPER_TOOLS_REPO_DIR}" >&2
      exit 1
    fi
  else
    mkdir -p "$(dirname -- "${HELPER_TOOLS_REPO_DIR}")"
    git clone \
      --branch "${HELPER_TOOLS_REPO_BRANCH}" \
      --single-branch \
      --depth 1 \
      "${HELPER_TOOLS_REPO_URL}" \
      "${HELPER_TOOLS_REPO_DIR}"
  fi

  SCRIPT_DIR=${HELPER_TOOLS_REPO_DIR}
}

# Purpose:
#   Resolve a directory containing the split bootstrap delegate scripts.
# Parameters:
#   None.
# Returns:
#   0 when SCRIPT_DIR points at usable delegate scripts.
# Side effects:
#   May clone or update the managed helper checkout when local files are absent. Sets
#   SCRIPT_DIR.
function resolve_delegate_dir()
{
  local candidate_dir
  local has_required_delegates=false

  candidate_dir=$(local_script_dir)
  case "${RUST_ENTRYPOINT_PHASE}" in
    system)
      [[ -n "${candidate_dir}" && -f "${candidate_dir}/rust-entrypoint-system" ]] \
        && has_required_delegates=true
      ;;
    home)
      [[ -n "${candidate_dir}" && -f "${candidate_dir}/rust-entrypoint-home" ]] \
        && has_required_delegates=true
      ;;
    both)
      [[ -n "${candidate_dir}" ]] \
        && [[ -f "${candidate_dir}/rust-entrypoint-system" ]] \
        && [[ -f "${candidate_dir}/rust-entrypoint-home" ]] \
        && has_required_delegates=true
      ;;
  esac

  if "${has_required_delegates}"; then
    SCRIPT_DIR=${candidate_dir}
    return 0
  fi

  clone_or_update_delegate_repo
}

SCRIPT_DIR=
resolve_delegate_dir

case "${RUST_ENTRYPOINT_PHASE}" in
  system)
    exec bash "${SCRIPT_DIR}/rust-entrypoint-system"
    ;;
  home)
    exec bash "${SCRIPT_DIR}/rust-entrypoint-home"
    ;;
  both)
    bash "${SCRIPT_DIR}/rust-entrypoint-system"
    exec bash "${SCRIPT_DIR}/rust-entrypoint-home"
    ;;
esac
