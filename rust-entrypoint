#!/usr/bin/env bash

set -xeuo pipefail

export DEBIAN_FRONTEND=noninteractive

HELPER_TOOLS_REPO=${HELPER_TOOLS_REPO:-https://raw.githubusercontent.com/leynos/agent-helper-scripts/refs/heads/main}

if [ "$(whoami)" = root ]; then
  SUDO=
else
  SUDO=sudo
fi

install -d "${HOME}/.local/bin"
curl --no-progress-meter --proto '=https' --tlsv1.2 -sSf "${HELPER_TOOLS_REPO}/apt-update-if-stale" > "${HOME}/.local/bin/apt-update-if-stale"
chmod 700 "${HOME}/.local/bin/apt-update-if-stale"

function needs()
{
  ! command -v "$1" >/dev/null 2>&1
}

function append_block_if_missing()
{
  local file=$1
  local block=$2

  [[ -f "${file}" ]] || return 0
  if [[ $(<"${file}") == *"${block}"* ]]; then
    return 0
  fi
  if [[ -s "${file}" ]] && [[ $(tail -c1 "${file}" | wc -l) -eq 0 ]]; then
    printf '\n' >> "${file}"
  fi
  printf '%s\n' "${block}" >> "${file}"
}

function ensure_profile_path()
{
  local dir=$1
  local block

  read -r -d '' block <<__EOF__ || true
# Added by rust-entrypoint to keep helper tooling on PATH.
case ":\$PATH:" in
  *:"${dir}":*)
    ;;
  *)
    export PATH="${dir}:\$PATH"
    ;;
esac
__EOF__

  append_block_if_missing "${HOME}/.bashrc" "${block}"
}

function ensure_profile_sources_bashrc()
{
  local block

  read -r -d '' block <<'__EOF__' || true
# Added by rust-entrypoint so login shells pick up ~/.bashrc when Bash starts.
if [ -n "${BASH_VERSION:-}" ] && [ -f "$HOME/.bashrc" ]; then
  . "$HOME/.bashrc"
fi
__EOF__

  append_block_if_missing "${HOME}/.profile" "${block}"
}

function ensure_runtime_path()
{
  local dir=$1

  case ":${PATH}:" in
    *:"${dir}":*)
      ;;
    *)
      PATH="${dir}:${PATH}"
      ;;
  esac
}

ensure_profile_path "${HOME}/.local/bin"
ensure_profile_path "${HOME}/.cargo/bin"
ensure_profile_path "${HOME}/.bun/bin"
ensure_profile_sources_bashrc

ensure_runtime_path "${HOME}/.local/bin"
ensure_runtime_path "${HOME}/.cargo/bin"
ensure_runtime_path "${HOME}/.bun/bin"
export PATH

codename="$(
  # shellcheck source=/dev/null
  . /etc/os-release
  printf '%s\n' "${VERSION_CODENAME}"
)"

install -d /etc/apt/sources.list.d

cat >/etc/apt/sources.list.d/zz-fast-ubuntu.sources <<EOF
Types: deb
URIs: http://mirror.math.princeton.edu/pub/ubuntu/
Suites: ${codename} ${codename}-updates ${codename}-backports ${codename}-security
Components: main restricted universe multiverse
Signed-By: /usr/share/keyrings/ubuntu-archive-keyring.gpg
By-Hash: yes
EOF

# Disable the stock Ubuntu source definitions, but leave third-party repos alone.
[ ! -e /etc/apt/sources.list ] || mv -n -- /etc/apt/sources.list /etc/apt/sources.list.disabled
[ ! -e /etc/apt/sources.list.d/ubuntu.sources ] || mv -n -- /etc/apt/sources.list.d/ubuntu.sources /etc/apt/sources.list.d/ubuntu.sources.disabled

apt-get clean
rm -rf /var/lib/apt/lists/*

if needs uv; then
  curl --no-progress-meter -LsSf https://astral.sh/uv/install.sh | sh
  if [[ -f "$HOME/.local/bin/env" ]]; then
    # shellcheck source=/dev/null
    source "$HOME/.local/bin/env"
  fi
fi

if needs bun; then
  curl --no-progress-meter -fsSL https://bun.sh/install | bash
fi

if needs rustup; then
  curl --no-progress-meter --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
fi

if needs sudo; then
  # Fingers crossed this works. Assuming that systems without sudo will be running as root
  echo "export DEBIAN_FRONTEND=noninteractive" >> /root/.profile
  apt-update-if-stale
  apt-get install -y apt-utils
  apt-get install -y sudo
fi

if [[ -d "/usr/local/rustup" ]]; then
  $SUDO chmod -R a+rX,go-w "/usr/local/rustup"
fi

if needs wget; then
  $SUDO env DEBIAN_FRONTEND=noninteractive apt-update-if-stale
  $SUDO env DEBIAN_FRONTEND=noninteractive apt-get install -y apt-utils
  $SUDO env DEBIAN_FRONTEND=noninteractive apt-get install -y wget
fi

CARGO_KOPIA_SRC="${CARGO_HOME:-${HOME}/.cargo}"
CARGO_KOPIA_DEST="$(dirname "${CARGO_KOPIA_SRC}")"
mkdir -p "${CARGO_KOPIA_SRC}"
cat > "${CARGO_KOPIA_SRC}.kopiaignore" <<'EOF'
/*
!/.crates.toml
!/.crates2.json
!/bin
!/bin/**
EOF

if [[ -n "${KOPIA_BUCKET:-}" ]]; then
  $SUDO apt-update-if-stale
  $SUDO apt-get install -y kopia
  if (( ${KOPIA_CREATE:-0} )); then
    kopia repository create s3 \
      --bucket="${KOPIA_BUCKET:-}" \
      --endpoint="${KOPIA_ENDPOINT:-}" \
      --region="${KOPIA_REGION:-}" \
      --access-key="${AWS_ACCESS_KEY_ID:-}" \
      --secret-access-key="${AWS_SECRET_ACCESS_KEY:-}" \
      --prefix=cargo/
  fi
  kopia repository connect s3 \
    --bucket="${KOPIA_BUCKET:-}" \
    --endpoint="${KOPIA_ENDPOINT:-}" \
    --region="${KOPIA_REGION:-}" \
    --access-key="${AWS_ACCESS_KEY_ID:-}" \
    --secret-access-key="${AWS_SECRET_ACCESS_KEY:-}" \
    --prefix=cargo/
  $SUDO rm -f /root/.config/kopia/repository.config.update-info.json
  kopia snapshot restore latest --target-directory "$CARGO_KOPIA_DEST" || true
fi

tools=(
  get-markdown-tooling
  get-rust-tooling
  rust-setup
  get-github-tooling
  get-python-tooling
  install-skills
  install-hooks
  install-sub-agents
)

if (( ${WITH_ADD_REPOSITORIES:-1} )); then
  tools=(add-repositories "${tools[@]}")
fi

for tool in "${tools[@]}"; do
    echo "Running $tool..."
    curl --no-progress-meter --retry 5 --retry-connrefused -fsSL "${HELPER_TOOLS_REPO}/$tool" | bash -xeuo pipefail
done

if [[ -n "${KOPIA_BUCKET:-}" ]]; then
  kopia snapshot create "$CARGO_KOPIA_DEST"
fi

