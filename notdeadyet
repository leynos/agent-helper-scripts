#!/usr/bin/env bash
set -euo pipefail

real_compiler="$1"
shift

interval="${RUSTC_HEARTBEAT_SECS:-45}"
show_sccache_stats="${RUSTC_HEARTBEAT_SCCACHE_STATS:-0}"
verbose="${RUSTC_HEARTBEAT_VERBOSE:-0}"

crate_name="unknown"
stdin_arg_index=""
stdin_file=""
ticker=""
status=0

compiler_cmd=()
compiler_chain_message=""
sccache_auto_wrapped=0

should_auto_wrap_sccache() {
  [[ -n "${SCCACHE_BUCKET:-}" || -n "${SCCACHE_WEBDAV_ENDPOINT:-}" || -n "${SCCACHE_DIR:-}" ]]
}

compiler_basename() {
  basename -- "$1"
}

is_truthy() {
  case "$1" in
    1|true|TRUE|yes|YES|on|ON)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

log_verbose() {
  if is_truthy "$verbose"; then
    echo "$1" >&2
  fi
}

build_compiler_cmd() {
  if should_auto_wrap_sccache && [[ "$(compiler_basename "$real_compiler")" != "sccache" ]]; then
    if command -v sccache >/dev/null 2>&1; then
      compiler_cmd=("sccache" "$real_compiler")
      compiler_chain_message="[rustc-heartbeat] Auto-wrapping compiler with sccache because SCCACHE_BUCKET, SCCACHE_WEBDAV_ENDPOINT or SCCACHE_DIR is set: ${compiler_cmd[*]}"
      sccache_auto_wrapped=1
      return 0
    fi

    echo "[rustc-heartbeat] SCCACHE_BUCKET, SCCACHE_WEBDAV_ENDPOINT or SCCACHE_DIR is set, but sccache is not on PATH; proceeding without sccache" >&2
  fi

  compiler_cmd=("$real_compiler")
  compiler_chain_message="[rustc-heartbeat] Compiler chain: ${compiler_cmd[*]}"
}

is_sccache_wrapper() {
  [[ "${#compiler_cmd[@]}" -gt 0 ]] && [[ "$(compiler_basename "${compiler_cmd[0]}")" == "sccache" ]]
}

print_sccache_stats() {
  if [[ "$show_sccache_stats" == "1" ]] && is_sccache_wrapper; then
    {
      echo "[rustc-heartbeat] sccache stats:"
      "${compiler_cmd[0]}" --show-stats
    } >&2 || true
  fi
}

cleanup() {
  if [[ -n "$ticker" ]]; then
    kill "$ticker" 2>/dev/null || true
    wait "$ticker" 2>/dev/null || true
  fi
  if [[ -n "$stdin_file" && -f "$stdin_file" ]]; then
    rm -f "$stdin_file"
  fi
}

build_compiler_cmd

log_verbose "$compiler_chain_message"

# Try to extract a crate name for nicer logs.
for ((i=1; i<=$#; i++)); do
  if [[ "${!i}" == "--crate-name" ]]; then
    j=$((i + 1))
    crate_name="${!j:-unknown}"
  fi

  if [[ "${!i}" == "-" ]]; then
    stdin_arg_index="$i"
  fi
done

if [[ -n "$stdin_arg_index" ]] && [[ ! -t 0 ]]; then
  stdin_file="$(mktemp)"
  cat >"$stdin_file"
fi

python3 - "$interval" "$crate_name" <<'PY' &
import signal
import sys
import time


def handle_signal(_signum, _frame):
    raise SystemExit(0)


signal.signal(signal.SIGTERM, handle_signal)
signal.signal(signal.SIGINT, handle_signal)

interval = float(sys.argv[1])
crate_name = sys.argv[2]

while True:
    time.sleep(interval)
    timestamp = time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())
    print(
        f"[rustc-heartbeat] crate={crate_name} still compiling at {timestamp}",
        file=sys.stderr,
        flush=True,
    )
PY
ticker=$!

trap cleanup EXIT INT TERM

if [[ -n "$stdin_file" ]]; then
  args=("$@")
  args[$((stdin_arg_index - 1))]="$stdin_file"
  "${compiler_cmd[@]}" "${args[@]}" || status=$?
else
  "${compiler_cmd[@]}" "$@" || status=$?
fi

print_sccache_stats
exit "$status"
