#!/usr/bin/env bash
set -euo pipefail

real_compiler="$1"
shift

interval="${RUSTC_HEARTBEAT_SECS:-15}"
show_sccache_stats="${RUSTC_HEARTBEAT_SCCACHE_STATS:-0}"

crate_name="unknown"
stdin_arg_index=""
stdin_file=""
ticker_running=1
ticker=""
status=0

compiler_cmd=()
compiler_chain_message=""
sccache_auto_wrapped=0

should_auto_wrap_sccache() {
  [[ -n "${SCCACHE_BUCKET:-}" || -n "${SCCACHE_WEBDAV_ENDPOINT:-}" ]]
}

compiler_basename() {
  basename -- "$1"
}

build_compiler_cmd() {
  if should_auto_wrap_sccache && [[ "$(compiler_basename "$real_compiler")" != "sccache" ]]; then
    if command -v sccache >/dev/null 2>&1; then
      compiler_cmd=("sccache" "$real_compiler")
      compiler_chain_message="[rustc-heartbeat] Auto-wrapping compiler with sccache because SCCACHE_BUCKET or SCCACHE_WEBDAV_ENDPOINT is set: ${compiler_cmd[*]}"
      sccache_auto_wrapped=1
      return 0
    fi

    echo "[rustc-heartbeat] SCCACHE_BUCKET or SCCACHE_WEBDAV_ENDPOINT is set, but sccache is not on PATH; proceeding without sccache" >&2
  fi

  compiler_cmd=("$real_compiler")
  compiler_chain_message="[rustc-heartbeat] Compiler chain: ${compiler_cmd[*]}"
}

is_sccache_wrapper() {
  [[ "${#compiler_cmd[@]}" -gt 0 ]] && [[ "$(compiler_basename "${compiler_cmd[0]}")" == "sccache" ]]
}

print_sccache_stats() {
  if [[ "$show_sccache_stats" == "1" ]] && is_sccache_wrapper; then
    {
      echo "[rustc-heartbeat] sccache stats:"
      "${compiler_cmd[0]}" --show-stats
    } >&2 || true
  fi
}

cleanup() {
  ticker_running=0
  if [[ -n "$ticker" ]]; then
    kill "$ticker" 2>/dev/null || true
  fi
  if [[ -n "$stdin_file" && -f "$stdin_file" ]]; then
    rm -f "$stdin_file"
  fi
}

build_compiler_cmd

echo "$compiler_chain_message" >&2

# Try to extract a crate name for nicer logs.
for ((i=1; i<=$#; i++)); do
  if [[ "${!i}" == "--crate-name" ]]; then
    j=$((i + 1))
    crate_name="${!j:-unknown}"
  fi

  if [[ "${!i}" == "-" ]]; then
    stdin_arg_index="$i"
  fi
done

if [[ -n "$stdin_arg_index" ]] && [[ ! -t 0 ]]; then
  stdin_file="$(mktemp)"
  cat >"$stdin_file"
fi

(
  while [[ "$ticker_running" -eq 1 ]]; do
    printf '[rustc-heartbeat] crate=%s still compiling at %(%FT%TZ)T\n' \
      "$crate_name" -1 >&2
    sleep "$interval"
  done
) &
ticker=$!

trap cleanup EXIT INT TERM

if [[ -n "$stdin_file" ]]; then
  args=("$@")
  args[$((stdin_arg_index - 1))]="$stdin_file"
  "${compiler_cmd[@]}" "${args[@]}" || status=$?
else
  "${compiler_cmd[@]}" "$@" || status=$?
fi

print_sccache_stats
exit "$status"
