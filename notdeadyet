#!/usr/bin/env bash
set -euo pipefail

real_compiler="$1"
shift

interval="${RUSTC_HEARTBEAT_SECS:-15}"
show_sccache_stats="${RUSTC_HEARTBEAT_SCCACHE_STATS:-0}"

is_sccache_wrapper() {
  local exe
  [[ -n "${RUSTC_WORKSPACE_WRAPPER:-}" ]]
  exe="$(basename -- "${RUSTC_WORKSPACE_WRAPPER:-}")"
  [[ "$exe" == "sccache" ]]
}

print_sccache_stats() {
  if [[ "$show_sccache_stats" == "1" ]] && is_sccache_wrapper; then
    {
      echo "[rustc-heartbeat] sccache stats:"
      "$real_compiler" --show-stats
    } >&2 || true
  fi
}

echo "[rustc-heartbeat] Wrapped compiler: $(basename -- "${RUSTC_WORKSPACE_WRAPPER:-}")" >&2
echo "[rustc-heartbeat] Show sccache stats: ${show_sccache_stats}" >&2

# Try to extract a crate name for nicer logs.
crate_name="unknown"
stdin_arg_index=""
for ((i=1; i<=$#; i++)); do
  if [[ "${!i}" == "--crate-name" ]]; then
    j=$((i + 1))
    crate_name="${!j:-unknown}"
  fi

  if [[ "${!i}" == "-" ]]; then
    stdin_arg_index="$i"
  fi
done

stdin_file=""
if [[ -n "$stdin_arg_index" ]] && [[ ! -t 0 ]]; then
  stdin_file="$(mktemp)"
  cat >"$stdin_file"
fi

ticker_running=1
(
  while [[ "$ticker_running" -eq 1 ]]; do
    printf '[rustc-heartbeat] crate=%s still compiling at %(%FT%TZ)T\n' \
      "$crate_name" -1 >&2
    sleep "$interval"
  done
) &
ticker=$!

cleanup() {
  ticker_running=0
  kill "$ticker" 2>/dev/null || true
  if [[ -n "$stdin_file" && -f "$stdin_file" ]]; then
    rm -f "$stdin_file"
  fi
}
trap cleanup EXIT INT TERM

status=0
if [[ -n "$stdin_file" ]]; then
  args=("$@")
  args[$((stdin_arg_index - 1))]="$stdin_file"
  "$real_compiler" "${args[@]}" || status=$?
else
  "$real_compiler" "$@" || status=$?
fi

print_sccache_stats
exit "$status"
