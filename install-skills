#!/usr/bin/env bash
set -euo pipefail

# Install skills to Codex and Claude config directories

REPO_URL="https://github.com/leynos/agent-helper-scripts.git"
REPO_DIR="${REPO_DIR:-${HELPER_TOOLS_REPO_DIR:-${HOME}/git/agent-helper-scripts}}"
HELPER_TOOLS_REPO_BRANCH="${HELPER_TOOLS_REPO_BRANCH:-main}"

NEXTEST_SKILL_REPO_URL="https://github.com/leynos/nextest-skill.git"
NEXTEST_SKILL_REPO_DIR="${HOME}/git/nextest-skill"

VIDAI_MOCK_SKILL_REPO_URL="https://github.com/leynos/vidai-mock-skill.git"
VIDAI_MOCK_SKILL_REPO_DIR="${HOME}/git/vidai-mock-skill"

RUST_SKILL_REPO_URL="https://github.com/leynos/rust-skill.git"
RUST_SKILL_REPO_DIR="${HOME}/git/rust-skill"

CODEX_SKILLS_DIR="${HOME}/.codex/skills"
CLAUDE_SKILLS_DIR="${HOME}/.claude/skills"

function clone_or_update_repo() {
  local repo_url=$1
  local repo_dir=${2%/}
  local sparse_set=${3:-}
  local repo_branch=${4:-}
  local parent=${repo_dir%/*}
  # Clone or update the repo
  mkdir -p "${parent}"
  if [[ -d "${repo_dir}" ]]; then
    echo "Updating existing repo at ${repo_dir}..."
    if [[ -n "${repo_branch}" ]]; then
      git -C "${repo_dir}" fetch --depth 1 origin "${repo_branch}"
      git -C "${repo_dir}" reset --hard FETCH_HEAD
    else
      git -C "${repo_dir}" fetch origin
      git -C "${repo_dir}" reset --hard origin/HEAD
    fi
  else
    if [[ -n "${sparse_set}" ]]; then
      echo "Cloning sparse set '${sparse_set}' from repo to ${repo_dir}..."
      if [[ -n "${repo_branch}" ]]; then
        git clone --branch "${repo_branch}" --single-branch --depth 1 --filter=blob:none --sparse "${repo_url}" "${repo_dir}"
      else
        git clone --depth 1 --filter=blob:none --sparse "${repo_url}" "${repo_dir}"
      fi
    else
      echo "Cloning from repo to ${repo_dir}..."
      if [[ -n "${repo_branch}" ]]; then
        git clone --branch "${repo_branch}" --single-branch --depth 1 "${repo_url}" "${repo_dir}"
      else
        git clone --depth 1 "${repo_url}" "${repo_dir}"
      fi
    fi
  fi

  if [[ -n "${sparse_set}" ]]; then
    git -C "${repo_dir}" sparse-checkout set "${sparse_set}"
  fi
}

clone_or_update_repo "${REPO_URL}" "${REPO_DIR}" "skills" "${HELPER_TOOLS_REPO_BRANCH}"
clone_or_update_repo "${NEXTEST_SKILL_REPO_URL}" "${NEXTEST_SKILL_REPO_DIR}"
clone_or_update_repo "${VIDAI_MOCK_SKILL_REPO_URL}" "${VIDAI_MOCK_SKILL_REPO_DIR}"
clone_or_update_repo "${RUST_SKILL_REPO_URL}" "${RUST_SKILL_REPO_DIR}" "skills"

function copy_skills() {
  local skills_src="$1"
 
  # Validate skills directory exists
  if [[ ! -d "${skills_src}" ]]; then
    echo "Error: Skills directory not found at ${skills_src}" >&2
    exit 1
  fi
  
  # Create destination directories
  mkdir -p "${CODEX_SKILLS_DIR}"
  mkdir -p "${CLAUDE_SKILLS_DIR}"
  
  # Copy skills to both destinations
  fd --type d --min-depth 1 --max-depth 1 . "$skills_src" -X cp -a -t "${CODEX_SKILLS_DIR}/"
  fd --type d --min-depth 1 --max-depth 1 . "$skills_src" -X cp -a -t "${CLAUDE_SKILLS_DIR}/"
  
  echo "Skills (${skills_src}) installed to:"
  echo "  ${CODEX_SKILLS_DIR}"
  echo "  ${CLAUDE_SKILLS_DIR}"
}

copy_skills "${REPO_DIR}/skills"
copy_skills "${NEXTEST_SKILL_REPO_DIR}"
copy_skills "${VIDAI_MOCK_SKILL_REPO_DIR}"
copy_skills "${RUST_SKILL_REPO_DIR}/skills"
