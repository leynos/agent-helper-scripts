#!/usr/bin/env bash

# Prepare an optional per-project Rust pre-build.
# The script is normally skipped during warm-home cache creation and runs cargo
# metadata/check only when RUST_PRE_BUILD is enabled.

set -euo pipefail

RUST_PRE_BUILD=${RUST_PRE_BUILD:-0}
RUST_ANALYZER_PRECHECK=${RUST_ANALYZER_PRECHECK:-0}

# Purpose:
#   Preload Rust dependency and analysis state for the current project.
# Parameters:
#   None.
# Returns:
#   0 when cargo metadata, cargo check, and optional rust-analyzer checks pass.
# Side effects:
#   Runs cargo in the current workspace and may update Cargo build artifacts.
perform_rust_pre_build() {
  cargo metadata --format-version=1 >/dev/null
  cargo check --workspace --all-targets

  if ((RUST_ANALYZER_PRECHECK)) && command -v rust-analyzer >/dev/null 2>&1; then
    rust-analyzer analysis-stats .
  fi
}

# Pre-build the package
if ! ((RUST_PRE_BUILD)); then
  echo "Skipping pre-install of dependencies with cargo build."
elif ! perform_rust_pre_build; then
  echo "Preparing rust environment failed."
fi
