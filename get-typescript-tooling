#!/usr/bin/env bash
# Installs TypeScript tooling into the user environment using bun.
# Installs `@biomejs/biome` and `@typescript/native-preview` globally via bun,
# and creates a tsc -> tsgo symlink under ~/.bin/bin.
# Requires: bun

if [[ "${WITH_TRACE:-0}" =~ ^(1|true|TRUE|yes|YES|on|ON)$ ]]; then
  set -x
fi

unset npm_config_http_proxy
bun install --global @biomejs/biome @typescript/native-preview
ln -s "${HOME}/.bin/bin/tsgo" "${HOME}/.bin/bin/tsc"
