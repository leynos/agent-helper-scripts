#!/usr/bin/env bash

# Install PostgreSQL server and client libraries.
# Required APT packages are declared via # requires-apt-packages: directives
# and delegated to install-required-apt-packages before any other work is done.

set -Eeuo pipefail

# requires-apt-packages: postgresql postgresql-contrib

SCRIPT_DIR=$(
  cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd
)

bash "${SCRIPT_DIR}/install-required-apt-packages" "$0"
