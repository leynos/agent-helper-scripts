#!/usr/bin/env bash

# Format and lint all Markdown files in the repository.
# The script finds Markdown-like files and runs mdtablefix followed by
# markdownlint --fix over the discovered file set.

set -xeu

# Purpose:
#   Run a command with all Markdown-like files as positional arguments.
# Parameters:
#   $@ - Command and arguments to invoke through xargs.
# Returns:
#   0 when the command succeeds for the discovered file set.
# Side effects:
#   Runs fd and xargs, then executes the requested command.
with_all_md() {
  if [[ $# -eq 0 ]]; then
    echo "Usage: with_all_md <command> [args...]" >&2
    return 1
  fi
  fd --print0 \
   --type f \
   --extension md \
   --extension markdown \
   --extension mdx \
   . | xargs -0 "$@"
}

with_all_md mdtablefix --wrap --renumber --breaks --ellipsis --fences --in-place
with_all_md markdownlint --fix
