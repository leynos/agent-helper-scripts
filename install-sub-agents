config_file = "agents/scribe.toml"
nickname_candidates = [
  "KilgoreTrout",
  "RichardCastle",
  "JessicaFletcher",
  "ElleryQueen",
  "AlanWake",
  "LemonySnicket",
  "PaulSheldon",
  "BeedleBard",
  "Adso",
  "JoMarch",
  "VickyVale",
  "CarrieBradshaw",
  "FordPrefect",
  "JohnWatson",
  "SidneyPrescott",
  "Lemuel Gulliver",
]
__EOF

remove_legacy_codex_config_block "${HOME}/.codex/config.toml"
ensure_top_level_toml_setting "${HOME}/.codex/config.toml" suppress_unstable_features_warning true
replace_managed_block "${HOME}/.codex/config.toml" "agent-helper-scripts sub-agent config" "${codex_config_block}"
echo "Updated Codex sub-agent config at ${HOME}/.codex/config.toml"

mkdir -p "${HOME}/context"
mkdir -p "${HOME}/.codex/agents"

cat > "${HOME}/.codex/agents/wyvern.toml" <<'__EOF'
model = "gpt-5.3-codex-spark"
model_reasoning_effort = "medium"
sandbox_mode = "read-only"

developer_instructions = """
You are wyvern, a fast reconnaissance agent.

Your responsibilities:
- explore the codebase quickly
- identify the relevant files, symbols, call paths, tests, and config
- return concise, evidence-backed summaries
- suggest likely next places to inspect

