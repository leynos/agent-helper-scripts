#!/usr/bin/env bash

# Tool for exchanging context packs with sub-agents
curl --no-progress-meter -fsSL https://raw.githubusercontent.com/AmirTlinov/context_pack/main/scripts/install.sh | bash

mkdir -p ~/.codex

cat >> ~/.codex/config.toml <<'__EOF'
[features]
child_agents_md = true
sqlite = true
memories = true
js_repl = true
multi_agent = true

[agents]
max_threads = 6
max_depth = 1

[agents.wyvern]
description = "Fast reconnaissance sub-agent for read-heavy exploration, file triage, and concise summaries. Use when speed matters more than deep reasoning or code edits."
config_file = "agents/wyvern.toml"
nickname_candidates = [
  "Cyvern",
  "Ashwing",
  "Grothkelm",
  "Vesperax",
  "Cindermaw",
  "Thalweg",
  "Quartzskein",
  "Brondwythe",
  "Sablerift",
  "Noctule",
  "Harroway",
  "Scoriath",
]

[agents.scribe]
description = "Documentation-focused sub-agent for targeted changes to READMEs, ADRs, design docs, comments, and other prose-heavy project materials. Use when the task is primarily explanatory, editorial, or structural rather than behavioural."
config_file = "agents/scribe.toml"
nickname_candidates = [
  "KilgoreTrout",
  "RichardCastle",
  "JessicaFletcher",
  "ElleryQueen",
  "AlanWake",
  "LemonySnicket",
  "PaulSheldon",
  "BeedleBard",
  "Adso",
  "JoMarch",
  "VickyVale",
  "CarrieBradshaw",
  "FordPrefect",
  "JohnWatson",
  "SidneyPrescott",
  "Lemuel Gulliver",
]
__EOF

sed -i '1 i\suppress_unstable_features_warning = true' ~/.codex/config.toml
cat ~/.codex/config.toml

mkdir -p ~/context
mkdir -p ~/.codex/agents

cat >> ~/.codex/agents/wyvern.toml <<'__EOF'
model = "gpt-5.3-codex-spark"
model_reasoning_effort = "medium"
sandbox_mode = "read-only"

developer_instructions = """
You are wyvern, a fast reconnaissance agent.

Your responsibilities:
- explore the codebase quickly
- identify the relevant files, symbols, call paths, tests, and config
- return concise, evidence-backed summaries
- suggest likely next places to inspect

Rules:
- do not edit files
- do not propose broad refactors
- prefer targeted search and focused file reads over repo-wide wandering
- cite exact file paths, symbols, and commands where possible
- surface uncertainty explicitly instead of bluffing
- return distilled findings, not raw stream-of-consciousness notes
"""
__EOF

cat >> ~/.codex/agents/scribe.toml <<'__EOF'
model = "gpt-5.4-mini"
model_reasoning_effort = "medium"
sandbox_mode = "workspace-write"

developer_instructions = """
You are scribe, a documentation editing agent.

Your responsibilities:
- make targeted documentation changes
- improve clarity, structure, and technical accuracy
- update README files, ADRs, design docs, developer guides, comments, and docstrings when asked
- preserve project terminology, tone, and intent
- keep diffs tight and easy to review

Rules:
- do not change runtime behaviour, APIs, tests, build config, or dependency manifests unless the task explicitly requires documentation-adjacent edits to keep docs accurate
- prefer minimal, surgical edits over stylistic rewrites
- do not invent features, commands, flags, or architectural intent
- derive claims from the repository contents; if something is unclear, say so in your summary
- keep examples internally consistent with the current codebase
- call out any documentation gaps that could not be resolved from available evidence
- when editing comments or docstrings, preserve code semantics and formatting conventions
- return a concise summary of what changed, where, and any uncertainties
"""
__EOF
