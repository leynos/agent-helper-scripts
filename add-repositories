#!/usr/bin/env bash

# Configure third-party APT repositories used by the helper bootstrap.
# The script installs keyrings and source-list files idempotently, tracks
# whether repository files changed, and refreshes APT package lists only when
# repository state changed or the lists are missing.

set -Eeuo pipefail
if [[ "${WITH_TRACE:-0}" =~ ^(1|true|TRUE|yes|YES|on|ON)$ ]]; then
  set -x
fi

SCRIPT_NAME=$(basename "$0")
REPOSITORIES_CHANGED=0

# Purpose:
#   Report the failing line for repository setup errors.
# Parameters:
#   $1 - Line number supplied by the ERR trap.
# Returns:
#   Does not return; exits with the original failing command status.
# Side effects:
#   Writes a diagnostic to stderr.
function on_error()
{
  local exit_code=$?
  local line_number=$1

  printf '%s\n' "${SCRIPT_NAME}: repository setup failed near line ${line_number}" >&2
  exit "${exit_code}"
}

trap 'on_error ${LINENO}' ERR

if [ "$(whoami)" = root ]; then
  SUDO=
else
  SUDO=sudo
fi

# Purpose:
#   Install a generated file only when its content differs from the target.
# Parameters:
#   $1 - File mode to pass to install.
#   $2 - Destination path.
#   $3 - Temporary source file containing the desired content.
# Returns:
#   0 when the destination already matches or installation succeeds.
# Side effects:
#   Writes the destination through sudo when needed and marks repository state
#   as changed.
function install_if_changed()
{
  local mode=$1
  local destination=$2
  local tmp=$3

  if [[ -f "${destination}" ]] && cmp -s "${tmp}" "${destination}"; then
    return 0
  fi

  $SUDO install -m "${mode}" "${tmp}" "${destination}"
  REPOSITORIES_CHANGED=1
}

# Purpose:
#   Detect whether APT currently has package-list index files.
# Parameters:
#   None.
# Returns:
#   0 when at least one non-empty APT index file exists; non-zero otherwise.
# Side effects:
#   Reads /var/lib/apt/lists.
function apt_lists_exist()
{
  find /var/lib/apt/lists \
    -mindepth 1 \
    -maxdepth 1 \
    -type f \
    -size +0c \
    ! -name lock \
    ! -path '*/partial/*' \
    \( \
      -name '*_Packages' \
      -o -name '*_Packages.*' \
      -o -name '*_Sources' \
      -o -name '*_Sources.*' \
      -o -name '*_Release' \
      -o -name '*_InRelease' \
      -o -name 'Release' \
    \) \
    -print \
    -quit \
    2>/dev/null | grep -q .
}

# Purpose:
#   Download and install an already-armored APT keyring file.
# Parameters:
#   $1 - HTTPS URL to download.
#   $2 - Destination keyring path.
# Returns:
#   0 when download and installation succeed.
# Side effects:
#   Creates a temporary file, downloads remote content, and writes a keyring.
function install_keyring()
{
  local url=$1
  local destination=$2
  local tmp

  tmp=$(mktemp)
  curl --no-progress-meter --proto '=https' --tlsv1.2 -fsSL "${url}" -o "${tmp}"
  install_if_changed 644 "${destination}" "${tmp}"
  rm -f "${tmp}"
}

# Purpose:
#   Download, dearmor, and install an ASCII-armored APT signing key.
# Parameters:
#   $1 - HTTPS URL to download.
#   $2 - Destination keyring path for the dearmored key.
# Returns:
#   0 on success; non-zero when download or dearmoring fails.
# Side effects:
#   Creates temporary files, invokes gpg, and writes a keyring when content
#   changed.
function install_dearmored_keyring()
{
  local url=$1
  local destination=$2
  local downloaded_tmp
  local dearmored_tmp

  downloaded_tmp=$(mktemp)
  dearmored_tmp=$(mktemp)

  if ! curl --no-progress-meter --proto '=https' --tlsv1.2 -fsSL "${url}" -o "${downloaded_tmp}"; then
    rm -f "${downloaded_tmp}" "${dearmored_tmp}"
    return 1
  fi

  if ! gpg --batch --yes --no-tty --dearmor --output "${dearmored_tmp}" "${downloaded_tmp}"; then
    rm -f "${downloaded_tmp}" "${dearmored_tmp}"
    return 1
  fi

  install_if_changed 644 "${destination}" "${dearmored_tmp}"
  rm -f "${downloaded_tmp}" "${dearmored_tmp}"
}

# Purpose:
#   Install an APT source-list file from standard input.
# Parameters:
#   $1 - Destination source-list path.
# Returns:
#   0 when installation succeeds or the destination already matches.
# Side effects:
#   Reads stdin, creates a temporary file, and writes the destination when
#   content changed.
function install_source()
{
  local destination=$1
  local tmp

  tmp=$(mktemp)
  cat > "${tmp}"
  install_if_changed 644 "${destination}" "${tmp}"
  rm -f "${tmp}"
}

$SUDO mkdir -p -m 755 /etc/apt/keyrings /etc/apt/sources.list.d

install_keyring \
  https://cli.github.com/packages/githubcli-archive-keyring.gpg \
  /etc/apt/keyrings/githubcli-archive-keyring.gpg
install_source /etc/apt/sources.list.d/github-cli.list <<EOF
deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main
EOF

# GoReleaser's official install page still uses `trusted=yes` for this APT
# source and does not document a keyring-backed `signed-by=` alternative for
# `repo.goreleaser.com`. This disables APT signature verification for that
# repository, so keep the exception scoped to the `nfpm` bootstrap path and
# prefer version-pinned, checksum or cosign-verified `.deb` installs if we
# replace this flow later.
install_source /etc/apt/sources.list.d/goreleaser.list <<'EOF'
deb [trusted=yes] https://repo.goreleaser.com/apt/ /
EOF

if (( ${INSTALL_GLOW:-0} )); then
  install_dearmored_keyring \
    https://repo.charm.sh/apt/gpg.key \
    /etc/apt/keyrings/charm.gpg
  install_source /etc/apt/sources.list.d/charm.list <<'EOF'
deb [signed-by=/etc/apt/keyrings/charm.gpg] https://repo.charm.sh/apt/ * *
EOF
fi

if [[ -n "${KOPIA_BUCKET:-}" ]]; then
  install_dearmored_keyring \
    https://kopia.io/signing-key \
    /etc/apt/keyrings/kopia-keyring.gpg
  install_source /etc/apt/sources.list.d/kopia.list <<'EOF'
deb [signed-by=/etc/apt/keyrings/kopia-keyring.gpg] http://packages.kopia.io/apt/ stable main
EOF
fi

if ((REPOSITORIES_CHANGED)) || ! apt_lists_exist; then
  $SUDO apt-get update -y
fi
