#!/usr/bin/env bash

# Shared bootstrap helpers for the system and home rust-entrypoint phases.
# This file is sourced by entrypoints; it centralises repository selection,
# helper-list construction, sparse checkout handling, and small profile helpers
# without deciding which authority boundary the caller is allowed to mutate.

if [[ -n "${AGENT_HELPER_BOOTSTRAP_COMMON_SOURCED:-}" ]]; then
  return 0
fi
AGENT_HELPER_BOOTSTRAP_COMMON_SOURCED=1

export DEBIAN_FRONTEND=${DEBIAN_FRONTEND:-noninteractive}

HELPER_TOOLS_REPO_URL=${HELPER_TOOLS_REPO_URL:-https://github.com/leynos/agent-helper-scripts.git}
HELPER_TOOLS_REPO_BRANCH=${HELPER_TOOLS_REPO_BRANCH:-main}
HELPER_TOOLS_REPO_NAME=${HELPER_TOOLS_REPO_NAME:-${HELPER_TOOLS_REPO_URL##*/}}
HELPER_TOOLS_REPO_NAME=${HELPER_TOOLS_REPO_NAME%.git}
HELPER_TOOLS_REPO_DIR=${HELPER_TOOLS_REPO_DIR:-${HOME}/git/${HELPER_TOOLS_REPO_NAME}}
export HELPER_TOOLS_REPO_DIR
export HELPER_TOOLS_REPO_BRANCH

if [ "$(whoami)" = root ]; then
  SUDO=
else
  SUDO=sudo
fi

function needs()
{
  ! command -v "$1" >/dev/null 2>&1
}

if needs sudo && [[ -n "${SUDO}" ]]; then
  echo "Error: sudo is required when not running as root and is assumed to be preinstalled in this environment" >&2
  exit 1
fi

HELPER_TOOLS_SPARSE_PATHS=(
  add-repositories
  apt-update-if-stale
  bootstrap-common
  get-ai-tooling
  get-github-tooling
  get-markdown-tooling
  get-python-tooling
  get-postgresql
  get-rust-tooling
  install-required-apt-packages
  install-hooks
  install-skills
  install-sub-agents
  markdownlint
  mdformat-all
  notdeadyet
  rust-entrypoint
  rust-entrypoint-home
  rust-entrypoint-system
  rust-setup
  skills
)

function git_supports_sparse_checkout_skip_checks()
{
  local git_version
  git_version=$(git version | awk '{print $3}')
  printf '2.37.0\n%s\n' "${git_version}" | sort -V -C
}

function clone_or_update_helper_tools_repo()
{
  local checkout_dir=${1:-${HELPER_TOOLS_REPO_DIR}}
  local checkout_parent
  checkout_parent=$(dirname "${checkout_dir}")

  mkdir -p "${checkout_parent}"
  if [[ -d "${checkout_dir}/.git" ]]; then
    echo "Updating helper tools repo at ${checkout_dir}..."
    git -C "${checkout_dir}" fetch --depth 1 origin "${HELPER_TOOLS_REPO_BRANCH}"
    git -C "${checkout_dir}" reset --hard FETCH_HEAD
  elif [[ -e "${checkout_dir}" ]]; then
    echo "Error: ${checkout_dir} exists but is not a git checkout" >&2
    exit 1
  else
    echo "Cloning helper tools repo to ${checkout_dir}..."
    git clone \
      --branch "${HELPER_TOOLS_REPO_BRANCH}" \
      --single-branch \
      --depth 1 \
      --filter=blob:none \
      --sparse \
      "${HELPER_TOOLS_REPO_URL}" \
      "${checkout_dir}"
  fi

  if git_supports_sparse_checkout_skip_checks; then
    git -C "${checkout_dir}" sparse-checkout set --skip-checks "${HELPER_TOOLS_SPARSE_PATHS[@]}"
  else
    git -C "${checkout_dir}" sparse-checkout init --no-cone
    git -C "${checkout_dir}" sparse-checkout set "${HELPER_TOOLS_SPARSE_PATHS[@]}"
  fi
}

function install_helper_script()
{
  local script_name=$1
  local destination=${2:-"${HOME}/.local/bin/${script_name}"}
  local source_path="${HELPER_TOOLS_REPO_DIR}/${script_name}"

  if [[ ! -f "${source_path}" ]]; then
    echo "Error: expected ${source_path} from the cloned agent-helper-scripts repo" >&2
    exit 1
  fi

  install -d "$(dirname "${destination}")"
  install -m 0700 "${source_path}" "${destination}"
}

function append_block_if_missing()
{
  local file=$1
  local block=$2

  [[ -f "${file}" ]] || return 0
  if [[ $(<"${file}") == *"${block}"* ]]; then
    return 0
  fi
  if [[ -s "${file}" ]] && [[ $(tail -c1 "${file}" | wc -l) -eq 0 ]]; then
    printf '\n' >> "${file}"
  fi
  printf '%s\n' "${block}" >> "${file}"
}

function ensure_profile_path()
{
  local dir=$1
  local block

  read -r -d '' block <<__EOF__ || true
# Added by rust-entrypoint to keep helper tooling on PATH.
case ":\$PATH:" in
  *:"${dir}":*)
    ;;
  *)
    export PATH="${dir}:\$PATH"
    ;;
esac
__EOF__

  append_block_if_missing "${HOME}/.bashrc" "${block}"
}

function ensure_profile_sources_bashrc()
{
  local block

  read -r -d '' block <<'__EOF__' || true
# Added by rust-entrypoint so login shells pick up ~/.bashrc when Bash starts.
if [ -n "${BASH_VERSION:-}" ] && [ -f "$HOME/.bashrc" ]; then
  . "$HOME/.bashrc"
fi
__EOF__

  append_block_if_missing "${HOME}/.profile" "${block}"
}

function ensure_runtime_path()
{
  local dir=$1

  case ":${PATH}:" in
    *:"${dir}":*)
      ;;
    *)
      PATH="${dir}:${PATH}"
      ;;
  esac
}

function build_selected_tools()
{
  SELECTED_TOOLS=(
    get-rust-tooling
    rust-setup
    get-markdown-tooling
    get-github-tooling
    get-python-tooling
    install-skills
    install-hooks
    install-sub-agents
  )

  if (( ${WITH_AI_TOOLING:-0} )); then
    SELECTED_TOOLS+=(get-ai-tooling)
  fi
}

function package_scripts_for_tools()
{
  local helper_checkout=$1
  shift

  PACKAGE_SCRIPTS=()
  local tool
  for tool in "$@"; do
    if [[ "${tool}" == get-* ]] || [[ "${tool}" == install-* ]]; then
      PACKAGE_SCRIPTS+=("${helper_checkout}/${tool}")
    fi
  done
}
