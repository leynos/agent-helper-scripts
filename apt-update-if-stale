#!/usr/bin/env bash

# Refresh APT package lists only when they are missing or stale.
# The timestamp lives in system state instead of $HOME so warm-home caches do
# not suppress updates on fresh system layers.

set -euo pipefail
if [[ "${WITH_TRACE:-0}" =~ ^(1|true|TRUE|yes|YES|on|ON)$ ]]; then
  set -x
fi

# Purpose:
#   Detect the privilege escalation command needed for APT state changes.
# Parameters:
#   None.
# Returns:
#   Prints an empty string when running as root, otherwise prints sudo.
# Side effects:
#   Reads the shell EUID value.
function _detect_sudo()
{
  if [[ "${EUID}" -eq 0 ]]; then
    printf ''
  else
    printf 'sudo'
  fi
}

stamp=/var/lib/agent-helper-scripts/apt/update-success-epoch
now=$(date +%s)
last=$(cat "$stamp" 2>/dev/null || echo 0)
sudo_cmd=$(_detect_sudo)

# Purpose:
#   Detect whether APT currently has package-list files.
# Parameters:
#   None.
# Returns:
#   0 when at least one non-empty APT index file exists; non-zero otherwise.
# Side effects:
#   Reads /var/lib/apt/lists.
function apt_lists_exist()
{
  find /var/lib/apt/lists \
    -mindepth 1 \
    -maxdepth 1 \
    -type f \
    -size +0c \
    ! -name lock \
    ! -path '*/partial/*' \
    \( \
      -name '*_Packages' \
      -o -name '*_Packages.*' \
      -o -name '*_Sources' \
      -o -name '*_Sources.*' \
      -o -name '*_Release' \
      -o -name '*_InRelease' \
      -o -name 'Release' \
    \) \
    -print \
    -quit \
    2>/dev/null | grep -q .
}

if apt_lists_exist && [ $((now - last)) -lt 1800 ]; then
  exit 0
fi

$sudo_cmd install -d -m 0755 "$(dirname "$stamp")"
$sudo_cmd apt-get update
printf '%s\n' "$now" | $sudo_cmd tee "$stamp" >/dev/null
