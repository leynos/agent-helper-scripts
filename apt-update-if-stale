#!/usr/bin/env bash

# Refresh APT package lists only when they are missing or stale.
# The timestamp lives in system state instead of $HOME so warm-home caches do
# not suppress updates on fresh system layers.

set -euo pipefail

if [ "$(whoami)" = root ]; then
  SUDO=
else
  SUDO=sudo
fi

stamp=/var/lib/agent-helper-scripts/apt/update-success-epoch
now=$(date +%s)
last=$(cat "$stamp" 2>/dev/null || echo 0)

# Purpose:
#   Detect whether APT currently has package-list files.
# Parameters:
#   None.
# Returns:
#   0 when at least one non-empty APT index file exists; non-zero otherwise.
# Side effects:
#   Reads /var/lib/apt/lists.
function apt_lists_exist()
{
  find /var/lib/apt/lists \
    -mindepth 1 \
    -maxdepth 1 \
    -type f \
    -size +0c \
    \( \
      -name '*_Packages' \
      -o -name '*_Packages.*' \
      -o -name '*_Sources' \
      -o -name '*_Sources.*' \
      -o -name '*_Release' \
      -o -name '*_InRelease' \
      -o -name 'Release' \
    \) \
    -print \
    -quit \
    2>/dev/null | grep -q .
}

if apt_lists_exist && [ $((now - last)) -lt 1800 ]; then
  exit 0
fi

$SUDO install -d -m 0755 "$(dirname "$stamp")"
$SUDO apt-get update
printf '%s\n' "$now" | $SUDO tee "$stamp" >/dev/null
