#!/usr/bin/env bash

# Install GitHub-oriented developer tooling and CLI utilities.
# Required APT packages are declared via # requires-apt-packages: directives
# and installed by install-required-apt-packages before this script runs.
# Additional tooling not available through APT (e.g. mergiraf, cargo-binstall
# binaries) is installed directly by this script.

# requires-apt-packages: strace gdb bat ripgrep nano ed fd-find
# requires-apt-packages: ltrace valgrind bpfcc-tools bpftrace
# requires-apt-packages: lsof htop iotop ncdu tree delta tcpdump nmap
# requires-apt-packages: clang lldb eza fzf hyperfine shellcheck
# requires-apt-packages: libxslt1-dev gh nfpm podman bubblewrap proot mmdebstrap

if [[ -f "${HOME}/.cargo/env" ]]; then
    # shellcheck source=/dev/null
    . "${HOME}/.cargo/env"
fi

# Purpose:
#   Extract the expected checksum for a release artifact.
# Parameters:
#   $1 - Artifact filename to look up.
#   $2 - Checksum file path.
# Returns:
#   Prints the checksum to stdout.
# Side effects:
#   Reads the checksum file and exits if the artifact is missing.
function release_checksum()
{
  local artifact_name=$1
  local checksum_file=$2
  local expected_sha

  expected_sha=$(awk -v artifact_name="${artifact_name}" '$2 == artifact_name { print $1; exit }' "${checksum_file}")
  if [[ -z "${expected_sha}" ]]; then
    echo "Error: checksum for ${artifact_name} not found in ${checksum_file}" >&2
    exit 1
  fi

  printf '%s\n' "${expected_sha}"
}

# Purpose:
#   Resolve the act release archive name for the current OS and architecture.
# Parameters:
#   None.
# Returns:
#   Prints the archive filename to stdout.
# Side effects:
#   Runs uname and exits on unsupported platforms.
function act_archive_name()
{
  local os_name
  local arch_name

  case "$(uname -s)" in
    Darwin)
      os_name=Darwin
      ;;
    Linux)
      os_name=Linux
      ;;
    CYGWIN_NT*|MINGW*|MSYS_NT*)
      os_name=Windows
      ;;
    *)
      echo "Error: unsupported OS for act: $(uname -s)" >&2
      exit 1
      ;;
  esac

  case "$(uname -m)" in
    x86_64|amd64)
      arch_name=x86_64
      ;;
    i386|i686|x86)
      arch_name=i386
      ;;
    aarch64|arm64)
      arch_name=arm64
      ;;
    armv6*)
      arch_name=armv6
      ;;
    armv7*)
      arch_name=armv7
      ;;
    *)
      echo "Error: unsupported architecture for act: $(uname -m)" >&2
      exit 1
      ;;
  esac

  printf 'act_%s_%s.tar.gz\n' "${os_name}" "${arch_name}"
}

# Purpose:
#   Download, verify, and install the GitHub Actions act binary.
# Parameters:
#   None; reads ACT_VERSION from the environment.
# Returns:
#   0 when act is installed.
# Side effects:
#   Downloads checksums and an archive with vendcurl, extracts the archive, and
#   writes ~/.local/bin/act.
function install_act()
{
  local act_version=${ACT_VERSION:-latest}
  local archive_name
  local release_base
  local tmpdir
  local expected_sha

  archive_name=$(act_archive_name)
  if [[ "${act_version}" == latest ]]; then
    release_base=https://github.com/nektos/act/releases/latest/download
  else
    release_base="https://github.com/nektos/act/releases/download/${act_version}"
  fi

  tmpdir=$(mktemp -d)
  vendcurl "${release_base}/checksums.txt" "${tmpdir}/checksums.txt"
  expected_sha=$(release_checksum "${archive_name}" "${tmpdir}/checksums.txt")
  vendcurl --sha256 "${expected_sha}" "${release_base}/${archive_name}" "${tmpdir}/${archive_name}"
  tar -xzf "${tmpdir}/${archive_name}" -C "${tmpdir}"
  install -m 0755 "${tmpdir}/act" "${HOME}/.local/bin/act"
  rm -rf "${tmpdir}"
}

MERGIRAF_VERSION=${MERGIRAF_VERSION:-0.16.3}
DIFFTASTIC_VERSION=${DIFFTASTIC_VERSION:-0.68.0}
LETA_VERSION=${LETA_VERSION:-0.13.0}
ACTION_VALIDATOR_VERSION=${ACTION_VALIDATOR_VERSION:-0.9.0}
VK_VERSION=${VK_VERSION:-0.5.0}
mkdir -p "${HOME}/.local/bin"
pushd "${HOME}/.local/bin" || exit
vendcurl \
  "https://github.com/leynos/vk/releases/download/v${VK_VERSION}/vk" \
  vk
chmod 755 vk
popd || exit

uv tool install mbake
bun install -g pajv

ln -sf /usr/bin/fdfind "${HOME}/.local/bin/fd"

cargo binstall --no-confirm "mergiraf@${MERGIRAF_VERSION}"
cargo binstall --no-confirm "difftastic@${DIFFTASTIC_VERSION}"

pwd
cargo binstall --no-confirm "leta@${LETA_VERSION}"
if (( ${WITH_LETA_WORKSPACE_ADD:-1} )); then
  leta workspace add .
fi

mkdir -p "${HOME}/.local/bin"
pushd "${HOME}/.local/bin" || exit
CHECKMAKE_VERSION=${CHECKMAKE_VERSION:-0.2.2}
vendcurl \
  "https://github.com/checkmake/checkmake/releases/download/${CHECKMAKE_VERSION}/checkmake-${CHECKMAKE_VERSION}.linux.amd64" \
  checkmake
chmod 755 checkmake
popd || exit

git config --global merge.conflictStyle zdiff3

if ! [[ -f "${HOME}/.gitconfig" ]] || ! grep -q mergiraf "${HOME}/.gitconfig"; then
  cat >>"${HOME}/.gitconfig" <<'__EOF'
[merge "mergiraf"]
        name = mergiraf
        driver = mergiraf merge --git %O %A %B -s %S -x %X -y %Y -p %P -l %L
__EOF
  mkdir -p "${HOME}/.config/git"
  echo "* merge=mergiraf" >> "${HOME}/.config/git/attributes"
fi

install_act

cargo binstall --no-confirm "action-validator@${ACTION_VALIDATOR_VERSION}"

uv tool install --python 3.13 mcp-server-qdrant
