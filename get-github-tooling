#!/usr/bin/env bash

# Install GitHub-oriented developer tooling and CLI utilities.
# Required APT packages are declared via # requires-apt-packages: directives
# and installed by install-required-apt-packages before this script runs.
# Additional tooling not available through APT (e.g. mergiraf, cargo-binstall
# binaries) is installed directly by this script.

# requires-apt-packages: strace gdb bat ripgrep nano ed fd-find
# requires-apt-packages: ltrace valgrind bpfcc-tools bpftrace
# requires-apt-packages: lsof htop iotop ncdu tree delta tcpdump nmap
# requires-apt-packages: clang lldb eza fzf hyperfine shellcheck
# requires-apt-packages: libxslt1-dev gh nfpm podman bubblewrap proot mmdebstrap

if [ "$(whoami)" = root ]; then
  SUDO=
else
  SUDO=sudo
fi

if [[ -f "${HOME}/.cargo/env" ]]; then
    # shellcheck source=/dev/null
    . "${HOME}/.cargo/env"
fi

MERGIRAF_VERSION=${MERGIRAF_VERSION:-0.16.3}
DIFFTASTIC_VERSION=${DIFFTASTIC_VERSION:-0.68.0}
LETA_VERSION=${LETA_VERSION:-0.13.0}
ACTION_VALIDATOR_VERSION=${ACTION_VALIDATOR_VERSION:-0.9.0}
VK_VERSION=${VK_VERSION:-0.5.0}
mkdir -p "${HOME}/.local/bin"
pushd "${HOME}/.local/bin" || exit
curl --no-progress-meter --proto '=https' --tlsv1.2 -fsSL \
  "https://github.com/leynos/vk/releases/download/v${VK_VERSION}/vk" \
  -o vk
chmod 755 vk
popd || exit

uv tool install mbake
bun install -g pajv

# Tools to help developers
$SUDO apt-update-if-stale
$SUDO apt-get install -y linux-tools-common || true
$SUDO apt-get install -y linux-tools-generic || true

ln -s /usr/bin/fdfind "${HOME}/.local/bin/fd"

cargo binstall --no-confirm "mergiraf@${MERGIRAF_VERSION}"
cargo binstall --no-confirm "difftastic@${DIFFTASTIC_VERSION}"

pwd
cargo binstall --no-confirm "leta@${LETA_VERSION}"
leta workspace add .

mkdir -p "${HOME}/.local/bin"
pushd "${HOME}/.local/bin" || exit
CHECKMAKE_VERSION=${CHECKMAKE_VERSION:-0.2.2}
curl --no-progress-meter --proto '=https' --tlsv1.2 -fsSL \
  "https://github.com/checkmake/checkmake/releases/download/${CHECKMAKE_VERSION}/checkmake-${CHECKMAKE_VERSION}.linux.amd64" \
  -o checkmake
chmod 755 checkmake
popd || exit

git config --global merge.conflictStyle zdiff3

if ! [[ -f "${HOME}/.gitconfig" ]] || ! grep -q mergiraf "${HOME}/.gitconfig"; then
  cat >>"${HOME}/.gitconfig" <<'__EOF'
[merge "mergiraf"]
        name = mergiraf
        driver = mergiraf merge --git %O %A %B -s %S -x %X -y %Y -p %P -l %L
__EOF
  mkdir -p "${HOME}/.config/git"
  echo "* merge=mergiraf" >> "${HOME}/.config/git/attributes"
fi

pushd "${HOME}/.local" || exit
curl --no-progress-meter --proto '=https' --tlsv1.2 -sSf https://raw.githubusercontent.com/nektos/act/master/install.sh | $SUDO bash
popd || exit

cargo binstall --no-confirm "action-validator@${ACTION_VALIDATOR_VERSION}"

uv tool install --python 3.13 mcp-server-qdrant
