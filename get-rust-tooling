#!/usr/bin/env bash

case ":${PATH}:" in
    *:"${HOME}/.local/bin":*)
        ;;
    *)
        export PATH="${HOME}/.local/bin:$PATH"
        ;;
esac

if [ "$(whoami)" = root ]; then
  SUDO=;
else
  SUDO=sudo;
fi

function append_block_if_missing()
{
  local file=$1
  local marker=$2
  local block=$3
  local begin_sentinel="### BEGIN ${marker}"
  local end_sentinel="### END ${marker}"
  local tmp

  tmp=$(mktemp)

  if [[ -f "${file}" ]]; then
    awk -v begin_sentinel="${begin_sentinel}" -v end_sentinel="${end_sentinel}" '
      $0 == begin_sentinel {
        skip=1
        next
      }
      $0 == end_sentinel {
        skip=0
        next
      }
      !skip {
        print
      }
    ' "${file}" > "${tmp}"

    if [[ -s "${tmp}" ]] && [[ $(tail -c1 "${tmp}" | wc -l) -eq 0 ]]; then
      printf '\n' >> "${tmp}"
    fi
  else
    : > "${tmp}"
  fi

  printf '%s\n%s\n%s\n' "${begin_sentinel}" "${block}" "${end_sentinel}" >> "${tmp}"
  mv "${tmp}" "${file}"
}

CARGO_KOPIA_SRC="${CARGO_HOME:-${HOME}/.cargo}"
CARGO_KOPIA_DEST="$(dirname "${CARGO_KOPIA_SRC}")"
mkdir -p "${CARGO_KOPIA_SRC}"
cat > "${CARGO_KOPIA_SRC}.kopiaignore" <<'EOF'
/registry/**
/git/**
EOF

if [[ -n "${KOPIA_BUCKET:-}" ]]; then
  $SUDO apt-update-if-stale
  $SUDO apt-get install -y kopia
  if (( ${KOPIA_CREATE:-0} )); then
    kopia repository create s3 \
      --bucket="${KOPIA_BUCKET:-}" \
      --endpoint="${KOPIA_ENDPOINT:-}" \
      --region="${KOPIA_REGION:-}" \
      --access-key="${AWS_ACCESS_KEY_ID:-}" \
      --secret-access-key="${AWS_SECRET_ACCESS_KEY:-}" \
      --prefix=cargo/
  fi
  kopia repository connect s3 \
    --bucket="${KOPIA_BUCKET:-}" \
    --endpoint="${KOPIA_ENDPOINT:-}" \
    --region="${KOPIA_REGION:-}" \
    --access-key="${AWS_ACCESS_KEY_ID:-}" \
    --secret-access-key="${AWS_SECRET_ACCESS_KEY:-}" \
    --prefix=cargo/
  $SUDO rm -f /root/.config/kopia/repository.config.update-info.json
  kopia snapshot restore latest --target-directory "$CARGO_KOPIA_DEST" || true
fi

# Rust tooling
if [[ -n "${RUST_CHANNEL:-}" ]]; then
  channel=${RUST_CHANNEL}
elif [[ -f "rust-toolchain.toml" ]]; then
  channel=$(uv run -p 3.13 python -c 'import tomllib; print(tomllib.loads(open("rust-toolchain.toml", "r").read())["toolchain"]["channel"])')
else
  channel=stable
fi

$SUDO apt-update-if-stale
$SUDO apt-get install -y build-essential pkg-config libssl-dev ca-certificates libpq-dev libsqlite3-dev
$SUDO update-ca-certificates

WITH_LLVM_COV=${WITH_LLVM_COV:-1}
if ! which rustup >/dev/null 2>&1; then
  curl --no-progress-meter --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
fi
curl --no-progress-meter -L --proto '=https' --tlsv1.2 -sSf https://raw.githubusercontent.com/cargo-bins/cargo-binstall/main/install-from-binstall-release.sh | bash

rustup toolchain install "${channel}"
if [[ -f "${HOME}/.cargo/env" ]]; then
  cat > "${HOME}/.cargo/env" <<'__EOF'
case ":${PATH}:" in
    *:"${CARGO_HOME:-$HOME/.cargo}/bin":*)
        ;;
    *)
        export PATH="${CARGO_HOME:-$HOME/.cargo}/bin:$PATH"
        ;;
esac
__EOF
  # shellcheck source=/dev/null
  . "${HOME}/.cargo/env"
fi
rustup component add rustfmt --toolchain "${channel}"
rustup component add clippy --toolchain "${channel}"
if ((WITH_LLVM_COV)); then
  cargo binstall --locked --no-confirm cargo-llvm-cov
  rustup component add llvm-tools-preview --toolchain "${channel}"
fi
rustup component add rust-analyzer --toolchain "${channel}"

# Ensure nightly rustfmt installed
rustup toolchain install nightly
rustup component add rustfmt --toolchain nightly

if [[ -n "${SCCACHE_BUCKET:-}" ]] || [[ -n "${SCCACHE_WEBDAV_ENDPOINT:-}" ]]; then
  cargo binstall --no-confirm sccache
  read -r -d '' sccache_block <<'__EOF__' || true

# Disable incremental Rust compilation.
export CARGO_INCREMENTAL=0

# Start the local sccache server quietly if it is not already running.
sccache --start-server >/dev/null 2>&1 || true
__EOF__
  append_block_if_missing "${HOME}/.bashrc" "get-rust-tooling sccache bootstrap" "${sccache_block}"

  export CARGO_INCREMENTAL=0
  sccache --start-server >/dev/null 2>&1 || true
fi

curl --no-progress-meter --proto '=https' --tlsv1.2 -sSf https://raw.githubusercontent.com/leynos/agent-helper-scripts/refs/heads/main/notdeadyet > "${HOME}/.local/bin/notdeadyet"
chmod 700 "${HOME}/.local/bin/notdeadyet"
read -r -d '' rustc_wrapper_block <<'__EOF__' || true

export RUSTC_WRAPPER="${HOME}/.local/bin/notdeadyet"
export RUSTC_HEARTBEAT_SECS=20
__EOF__
append_block_if_missing "${HOME}/.bashrc" "get-rust-tooling rustc wrapper bootstrap" "${rustc_wrapper_block}"

export RUSTC_WRAPPER="${HOME}/.local/bin/notdeadyet"
export RUSTC_HEARTBEAT_SECS=20

cargo binstall --locked --no-confirm cargo-nextest
cargo binstall --locked --no-confirm kani-verifier

WITH_WHITAKER=${WITH_WHITAKER:-0}
WITH_WHITAKER_EXPERIMENTAL=${WITH_WHITAKER_EXPERIMENTAL:-0}
WHITAKER_INSTALLER_VERSION=${WHITAKER_INSTALLER_VERSION:-0.2.4}
if ((WITH_WHITAKER)); then
  whitaker_args=()
  if ((WITH_WHITAKER_EXPERIMENTAL)); then
    whitaker_args+=(--experimental)
  fi
  if ! {
    cargo binstall --locked --no-confirm "whitaker-installer@${WHITAKER_INSTALLER_VERSION}" && \
    whitaker-installer "${whitaker_args[@]}";
  }; then
    echo "Warning: Whitaker is not currently available in this environment"
  fi
fi

WITH_MOLD_LD_OVERRIDE=${WITH_MOLD_LD_OVERRIDE:-0}
MOLD_VERSION="${MOLD_VERSION:-2.40.4}"
url_preamble="https://github.com/rui314/mold/releases/download/"
assembled_url="${url_preamble}v${MOLD_VERSION}/mold-${MOLD_VERSION}-$(uname -m)-linux.tar.gz"
wget -O- --timeout=10 --waitretry=3 --retry-connrefused --progress=dot:mega "${assembled_url}" |
  $SUDO tar -C /usr/local --strip-components=1 --no-overwrite-dir -xzf -
if ((WITH_MOLD_LD_OVERRIDE)) && [[ "$(realpath /usr/bin/ld)" != /usr/local/bin/mold ]]; then
  $SUDO ln -sf /usr/local/bin/mold "$(realpath /usr/bin/ld)"
fi


if [[ -n "${KOPIA_BUCKET:-}" ]]; then
  kopia snapshot create "$CARGO_KOPIA_DEST"
fi
