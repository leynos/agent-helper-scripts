#!/usr/bin/env bash

# Install Rust toolchains and companion developer tooling.
# This script prepares the Rust compiler, supporting cargo utilities, and
# heartbeat wrappers, and it reuses files from the cloned `agent-helper-scripts`
# checkout for locally managed helper binaries.
# requires-apt-packages: build-essential pkg-config libssl-dev ca-certificates
# requires-apt-packages: libpq-dev libsqlite3-dev mold

case ":${PATH}:" in
    *:"${HOME}/.local/bin":*)
        ;;
    *)
        export PATH="${HOME}/.local/bin:$PATH"
        ;;
esac

HELPER_TOOLS_REPO_DIR=${HELPER_TOOLS_REPO_DIR:-${HOME}/git/agent-helper-scripts}

# Purpose:
#   Replace a managed block in a file, appending it when absent.
# Parameters:
#   $1 - File to update.
#   $2 - Marker name used in BEGIN/END sentinels.
#   $3 - Block content to write between sentinels.
# Returns:
#   0 when the file has been rewritten with the managed block.
# Side effects:
#   Creates a temporary file and replaces the target file.
function append_block_if_missing()
{
  local file=$1
  local marker=$2
  local block=$3
  local begin_sentinel="### BEGIN ${marker}"
  local end_sentinel="### END ${marker}"
  local tmp

  tmp=$(mktemp)

  if [[ -f "${file}" ]]; then
    awk -v begin_sentinel="${begin_sentinel}" -v end_sentinel="${end_sentinel}" '
      $0 == begin_sentinel {
        skip=1
        next
      }
      $0 == end_sentinel {
        skip=0
        next
      }
      !skip {
        print
      }
    ' "${file}" > "${tmp}"

    if [[ -s "${tmp}" ]] && [[ $(tail -c1 "${tmp}" | wc -l) -eq 0 ]]; then
      printf '\n' >> "${tmp}"
    fi
  else
    : > "${tmp}"
  fi

  printf '%s\n%s\n%s\n' "${begin_sentinel}" "${block}" "${end_sentinel}" >> "${tmp}"
  mv "${tmp}" "${file}"
}

# Rust tooling
if [[ -n "${RUST_CHANNEL:-}" ]]; then
  channel=${RUST_CHANNEL}
elif [[ -f "rust-toolchain.toml" ]]; then
  channel=$(uv run -p 3.13 python -c 'import tomllib; print(tomllib.loads(open("rust-toolchain.toml", "r").read())["toolchain"]["channel"])')
else
  channel=stable
fi

WITH_LLVM_COV=${WITH_LLVM_COV:-1}
CARGO_LLVM_COV_VERSION=${CARGO_LLVM_COV_VERSION:-0.8.5}
SCCACHE_VERSION=${SCCACHE_VERSION:-0.14.0}
CARGO_NEXTEST_VERSION=${CARGO_NEXTEST_VERSION:-0.9.133}
KANI_VERIFIER_VERSION=${KANI_VERIFIER_VERSION:-0.67.0}
if ! command -v rustup >/dev/null 2>&1; then
  curl --no-progress-meter --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
fi

cargo_binstall_tmp=$(mktemp -d)
trap 'rm -rf "${cargo_binstall_tmp}"' EXIT
pushd "${cargo_binstall_tmp}" || exit
vendcurl https://github.com/cargo-bins/cargo-binstall/releases/latest/download/cargo-binstall-x86_64-unknown-linux-musl.tgz
tar xvzf cargo-binstall-x86_64-unknown-linux-musl.tgz
./cargo-binstall --self-install || ./cargo-binstall -y --force cargo-binstall
rm -f ./cargo-binstall-x86_64-unknown-linux-musl.tgz ./cargo-binstall
popd || exit
rm -rf "${cargo_binstall_tmp}"
trap - EXIT

rustup toolchain install "${channel}"
if [[ -f "${HOME}/.cargo/env" ]]; then
  cat > "${HOME}/.cargo/env" <<'__EOF'
case ":${PATH}:" in
    *:"${CARGO_HOME:-$HOME/.cargo}/bin":*)
        ;;
    *)
        export PATH="${CARGO_HOME:-$HOME/.cargo}/bin:$PATH"
        ;;
esac
__EOF
  # shellcheck source=/dev/null
  . "${HOME}/.cargo/env"
fi
rustup component add rustfmt --toolchain "${channel}"
rustup component add clippy --toolchain "${channel}"
if ((WITH_LLVM_COV)); then
  cargo binstall --locked --no-confirm "cargo-llvm-cov@${CARGO_LLVM_COV_VERSION}"
  rustup component add llvm-tools-preview --toolchain "${channel}"
fi
rustup component add rust-analyzer --toolchain "${channel}"

# Ensure nightly rustfmt installed
rustup toolchain install nightly
rustup component add rustfmt --toolchain nightly

if [[ -n "${SCCACHE_BUCKET:-}" ]] || [[ -n "${SCCACHE_WEBDAV_ENDPOINT:-}" ]]; then
  cargo binstall --no-confirm "sccache@${SCCACHE_VERSION}"
  read -r -d '' sccache_block <<'__EOF__' || true

# Disable incremental Rust compilation.
export CARGO_INCREMENTAL=0

# Start the local sccache server quietly if it is not already running.
sccache --start-server >/dev/null 2>&1 || true
__EOF__
  append_block_if_missing "${HOME}/.bashrc" "get-rust-tooling sccache bootstrap" "${sccache_block}"

  export CARGO_INCREMENTAL=0
  sccache --start-server >/dev/null 2>&1 || true
fi

mkdir -p "${HOME}/.local/bin"
if [[ ! -f "${HELPER_TOOLS_REPO_DIR}/notdeadyet" ]]; then
  echo "Error: expected ${HELPER_TOOLS_REPO_DIR}/notdeadyet from the cloned agent-helper-scripts repo" >&2
  exit 1
fi
install -m 0700 "${HELPER_TOOLS_REPO_DIR}/notdeadyet" "${HOME}/.local/bin/notdeadyet"
read -r -d '' rustc_wrapper_block <<'__EOF__' || true

export RUSTC_WRAPPER="${HOME}/.local/bin/notdeadyet"
export RUSTC_HEARTBEAT_SECS=20
__EOF__
append_block_if_missing "${HOME}/.bashrc" "get-rust-tooling rustc wrapper bootstrap" "${rustc_wrapper_block}"

export RUSTC_WRAPPER="${HOME}/.local/bin/notdeadyet"
export RUSTC_HEARTBEAT_SECS=20

cargo binstall --locked --no-confirm "cargo-nextest@${CARGO_NEXTEST_VERSION}"
cargo binstall --locked --no-confirm "kani-verifier@${KANI_VERIFIER_VERSION}"

WITH_WHITAKER=${WITH_WHITAKER:-0}
WITH_WHITAKER_EXPERIMENTAL=${WITH_WHITAKER_EXPERIMENTAL:-0}
WHITAKER_INSTALLER_VERSION=${WHITAKER_INSTALLER_VERSION:-0.2.4}
if ((WITH_WHITAKER)); then
  whitaker_args=()
  if ((WITH_WHITAKER_EXPERIMENTAL)); then
    whitaker_args+=(--experimental)
  fi
  if ! {
    cargo binstall --locked --no-confirm "whitaker-installer@${WHITAKER_INSTALLER_VERSION}" && \
    whitaker-installer "${whitaker_args[@]}";
  }; then
    echo "Warning: Whitaker is not currently available in this environment"
  fi
fi
