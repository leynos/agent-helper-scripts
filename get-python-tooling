#!/usr/bin/env bash
# Installs Python tooling into the user environment using uv.
# Ensures ~/.local/bin is on PATH, then installs ruff, pyright, ty, pyscn,
# and basedpyright as uv tools.
# Requires: uv

if [[ "${WITH_TRACE:-0}" =~ ^(1|true|TRUE|yes|YES|on|ON)$ ]]; then
  set -x
fi

case ":${PATH}:" in
    *:"${HOME}/.local/bin":*)
        ;;
    *)
        export PATH="${HOME}/.local/bin:$PATH"
        ;;
esac

# Python tooling
uv tool install ruff
uv tool install 'pyright[nodejs]'
uv tool install ty
uv tool install pyscn
uv tool install basedpyright
