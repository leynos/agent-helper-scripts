#!/usr/bin/env bash

# Install markdown-focused tooling for helper-script environments.
# This script installs CLI tools used for linting, formatting, and Mermaid
# validation, and it expects helper-managed wrapper scripts to be available
# from the cloned `agent-helper-scripts` checkout.
# requires-apt-packages: libxcomposite1 libxdamage1 libxrandr2 libxss1 libxtst6
# requires-apt-packages: libgbm1 libdrm2 libxshmfence1 libnspr4 libnss3
# requires-apt-packages: libcups2t64 libasound2t64
# requires-apt-packages: libatk1.0-0t64 libatk-bridge2.0-0t64 libatspi2.0-0t64
# requires-apt-packages: libx11-xcb1 libxkbcommon0
# requires-apt-packages: libpango-1.0-0 libpangocairo-1.0-0
# requires-apt-packages: libgtk-3-0t64 libglib2.0-0t64
# requires-apt-packages: fonts-liberation ca-certificates
# requires-apt-packages: libx11-6 libxext6 libxfixes3 libxcb1

HELPER_TOOLS_REPO_DIR=${HELPER_TOOLS_REPO_DIR:-${HOME}/git/agent-helper-scripts}

# Purpose:
#   Install a repository-owned helper binary into ~/.local/bin.
# Parameters:
#   $1 - Binary/script name relative to HELPER_TOOLS_REPO_DIR.
# Returns:
#   0 when the source exists and installation succeeds.
# Side effects:
#   Creates ~/.local/bin and writes an executable helper file.
function get_bin() {
  local bin_name=$1
  local source_path="${HELPER_TOOLS_REPO_DIR}/${bin_name}"

  if [[ ! -f "${source_path}" ]]; then
    echo "Error: expected ${source_path} from the cloned agent-helper-scripts repo" >&2
    exit 1
  fi

  mkdir -p  "${HOME}/.local/bin"
  cp "${source_path}" "${HOME}/.local/bin/${bin_name}"
  chmod 0755 "${HOME}/.local/bin/${bin_name}"
}

WITH_VALE=${WITH_VALE:-0}
if ((WITH_VALE)); then
  uv tool install vale
  vale --version
fi

bun install --global markdownlint-cli2 markdown-table-formatter
get_bin markdownlint
time bun install --global @mermaid-js/mermaid-cli
uv tool install nixie-cli
get_bin mdformat-all

MDTABLEFIX_VERSION=${MDTABLEFIX_VERSION:-0.4.0}
cargo binstall --locked --no-confirm "mdtablefix@${MDTABLEFIX_VERSION}"
