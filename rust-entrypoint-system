#!/usr/bin/env bash

# System phase for Rust helper bootstrap.
# This entrypoint owns package repositories, package installation, certificate
# updates, and other machine-level mutations that are not preserved by a warm
# user-home cache.

set -euo pipefail
if [[ "${WITH_TRACE:-0}" =~ ^(1|true|TRUE|yes|YES|on|ON)$ ]]; then
  set -x
fi

SCRIPT_DIR=$(
  cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd
)

# shellcheck source=bootstrap-common
source "${SCRIPT_DIR}/bootstrap-common"

# Purpose:
#   Replace stock Ubuntu APT sources with the configured mirror.
# Parameters:
#   None.
# Returns:
#   0 when source files are written and APT list state is cleared.
# Side effects:
#   Reads /etc/os-release, writes /etc/apt/sources.list.d, disables stock
#   Ubuntu source files, cleans APT state, and removes /var/lib/apt/lists.
function configure_ubuntu_sources()
{
  local codename
  local sudo_cmd
  local ubuntu_sources_tmp
  local ubuntu_mirror=${UBUNTU_APT_MIRROR:-http://mirror.math.princeton.edu/pub/ubuntu/}

  codename="$(
    # shellcheck source=/dev/null
    . /etc/os-release
    printf '%s\n' "${VERSION_CODENAME}"
  )"
  sudo_cmd=$(_detect_sudo)
  ubuntu_sources_tmp=$(mktemp)
  cat > "${ubuntu_sources_tmp}" <<EOF
Types: deb
URIs: ${ubuntu_mirror}
Suites: ${codename} ${codename}-updates ${codename}-backports
Components: main restricted universe multiverse
Signed-By: /usr/share/keyrings/ubuntu-archive-keyring.gpg
By-Hash: yes

Types: deb
URIs: https://security.ubuntu.com/ubuntu
Suites: ${codename}-security
Components: main restricted universe multiverse
Signed-By: /usr/share/keyrings/ubuntu-archive-keyring.gpg
By-Hash: yes
EOF

  $sudo_cmd install -d /etc/apt/sources.list.d
  $sudo_cmd install -m 0644 "${ubuntu_sources_tmp}" /etc/apt/sources.list.d/zz-fast-ubuntu.sources
  rm -f "${ubuntu_sources_tmp}"

  # Disable the stock Ubuntu source definitions, but leave third-party repos alone.
  [ ! -e /etc/apt/sources.list ] || $sudo_cmd mv -n -- /etc/apt/sources.list /etc/apt/sources.list.disabled
  [ ! -e /etc/apt/sources.list.d/ubuntu.sources ] || $sudo_cmd mv -n -- /etc/apt/sources.list.d/ubuntu.sources /etc/apt/sources.list.d/ubuntu.sources.disabled

  $sudo_cmd apt-get clean
  $sudo_cmd sh -c 'rm -rf /var/lib/apt/lists/*'
}

# Purpose:
#   Run the APT update helper from the temporary system helper checkout.
# Parameters:
#   $1 - Path to the temporary helper checkout.
# Returns:
#   0 when the update helper succeeds.
# Side effects:
#   May refresh APT package lists.
function run_apt_update_if_stale()
{
  local helper_checkout=$1
  local sudo_cmd

  sudo_cmd=$(_detect_sudo)
  bootstrap_log "Checking APT freshness"
  $sudo_cmd bash "${helper_checkout}/apt-update-if-stale"
  bootstrap_log "APT update complete"
}

# Purpose:
#   Install required system packages in one apt-get transaction.
# Parameters:
#   $1 - Path to the temporary helper checkout.
#   $@ - Package names after the helper checkout argument.
# Returns:
#   0 when no packages are requested or installation succeeds.
# Side effects:
#   May refresh APT lists and install packages.
function install_system_packages()
{
  local helper_checkout=$1
  local sudo_cmd
  shift

  if [[ $# -eq 0 ]]; then
    return 0
  fi

  sudo_cmd=$(_detect_sudo)
  run_apt_update_if_stale "${helper_checkout}"
  bootstrap_log "Installing required packages: $*"
  $sudo_cmd env DEBIAN_FRONTEND=noninteractive apt-get install -y -- "$@"
}

# Purpose:
#   Attempt optional system-package installs without failing the phase.
# Parameters:
#   $1 - Path to the temporary helper checkout.
#   $@ - Package names after the helper checkout argument.
# Returns:
#   0 even when an individual package installation fails.
# Side effects:
#   May refresh APT lists and install packages.
function install_best_effort_system_packages()
{
  local helper_checkout=$1
  shift
  local package
  local sudo_cmd

  if [[ $# -eq 0 ]]; then
    return 0
  fi

  sudo_cmd=$(_detect_sudo)
  run_apt_update_if_stale "${helper_checkout}"
  bootstrap_log "Attempting linux-tools install (best-effort)"
  for package in "$@"; do
    bootstrap_log "Installing required packages: ${package}"
    $sudo_cmd env DEBIAN_FRONTEND=noninteractive apt-get install -y -- "${package}" || true
  done
}

sudo_cmd=$(_detect_sudo)
if [[ -n "${sudo_cmd}" ]]; then
  bootstrap_log "Using sudo for privileged ops"
else
  bootstrap_log "Running as root"
fi
if needs sudo && [[ -n "${sudo_cmd}" ]]; then
  bootstrap_log "Error: sudo is required for the system phase when not running as root"
  exit 1
fi
configure_ubuntu_sources
run_apt_update_if_stale "${SCRIPT_DIR}"
bootstrap_log "Installing required packages: ca-certificates curl git gnupg tar xz-utils unzip wget apt-utils"
$sudo_cmd env DEBIAN_FRONTEND=noninteractive apt-get install -y -- ca-certificates curl git gnupg tar xz-utils unzip wget apt-utils

if ! command -v git >/dev/null 2>&1; then
  bootstrap_log "Error: git is required but was not found on PATH after installation"
  exit 1
fi

# Create only the parent directory. clone_or_update_helper_tools_repo rejects
# existing non-git targets, so the checkout path itself must not pre-exist.
system_helper_parent=$(mktemp -d)
system_helper_checkout="${system_helper_parent}/agent-helper-scripts"
trap 'rm -rf "${system_helper_parent}"' EXIT
bootstrap_log "Cloning helper repo to ${system_helper_checkout}"
clone_or_update_helper_tools_repo "${system_helper_checkout}"
bootstrap_log "Helper repo ready at ${system_helper_checkout}"

if (( ${WITH_ADD_REPOSITORIES:-1} )); then
  bash -euo pipefail "${system_helper_checkout}/add-repositories"
fi

build_selected_tools
package_scripts_for_tools "${system_helper_checkout}" "${SELECTED_TOOLS[@]}"
if [[ ${#PACKAGE_SCRIPTS[@]} -gt 0 ]]; then
  bash -euo pipefail "${system_helper_checkout}/install-required-apt-packages" "${PACKAGE_SCRIPTS[@]}"
fi

optional_system_packages=()
if [[ -n "${KOPIA_BUCKET:-}" ]]; then
  optional_system_packages+=(kopia)
fi
if (( ${INSTALL_GLOW:-0} )); then
  optional_system_packages+=(glow)
fi
if [[ ${#optional_system_packages[@]} -gt 0 ]]; then
  install_system_packages "${system_helper_checkout}" "${optional_system_packages[@]}"
fi

install_best_effort_system_packages "${system_helper_checkout}" linux-tools-common linux-tools-generic

bootstrap_log "Updating CA certificates"
$sudo_cmd update-ca-certificates

if [[ -d "/usr/local/rustup" ]]; then
  $sudo_cmd chmod -R a+rX,go-w "/usr/local/rustup"
fi

if [[ -n "${KOPIA_BUCKET:-}" ]]; then
  $sudo_cmd rm -f /root/.config/kopia/repository.config.update-info.json
fi

if (( ${WITH_MOLD_LD_OVERRIDE:-0} )); then
  if [[ -x /usr/bin/mold ]]; then
    if [[ "$(realpath /usr/bin/ld)" != /usr/bin/mold ]]; then
      bootstrap_log "Overriding /usr/bin/ld → mold"
      $sudo_cmd ln -sf /usr/bin/mold /usr/bin/ld
    fi
  else
    bootstrap_log "Skipping mold ld override because /usr/bin/mold is not executable"
  fi
fi
