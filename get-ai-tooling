#!/usr/bin/env bash

# get-ai-tooling: installs optional AI-specific tooling into the user
# environment. Downloads and extracts the VidaiMock binary from its GitHub
# release and places it in ~/.local/bin. Invoked only when WITH_AI_TOOLING is
# enabled during the rust-entrypoint helper loop.

mkdir -p "${HOME}/git"
pushd "${HOME}/git" || exit
vendcurl https://github.com/vidaiUK/VidaiMock/releases/download/v0.1.2/vidaimock-linux-x64.tar.gz
tar -xzf vidaimock-linux-x64.tar.gz
mkdir -p "${HOME}/.local/bin"
cp vidaimock/vidaimock "${HOME}/.local/bin"
rm -f vidaimock-linux-x64.tar.gz
popd || exit
