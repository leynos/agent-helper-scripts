#!/usr/bin/env bash

# Scan selected helper scripts for # requires-apt-packages: directives and
# install the deduplicated union of those packages in a single apt-get
# transaction. Invoke this script with one or more script paths as arguments;
# it exits cleanly with no action when called with no arguments or when no
# directives are found.

set -Eeuo pipefail
if [[ "${WITH_TRACE:-0}" =~ ^(1|true|TRUE|yes|YES|on|ON)$ ]]; then
  set -x
fi

if [ "$(whoami)" = root ]; then
  SUDO=
else
  SUDO=sudo
fi

SCRIPT_DIR=$(
  cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd
)

# Purpose:
#   Run the repository-local or PATH-provided APT update helper.
# Parameters:
#   None.
# Returns:
#   0 when the update helper succeeds.
# Side effects:
#   May invoke sudo and may refresh /var/lib/apt/lists through apt-get update.
function run_apt_update_if_stale()
{
  local apt_update_script

  apt_update_script=$(command -v apt-update-if-stale 2>/dev/null) || apt_update_script="${SCRIPT_DIR}/apt-update-if-stale"

  if [[ -n "${SUDO}" ]]; then
    $SUDO bash "${apt_update_script}"
  else
    bash "${apt_update_script}"
  fi
}

if [[ $# -eq 0 ]]; then
  exit 0
fi

declare -A seen_packages=()
packages=()

for script_path in "$@"; do
  if [[ ! -f "${script_path}" ]]; then
    echo "Error: script not found: ${script_path}" >&2
    exit 1
  fi

  while IFS= read -r line; do
    if [[ "${line}" =~ ^#[[:space:]]*requires-apt-packages:[[:space:]]*(.*)$ ]]; then
      for package in ${BASH_REMATCH[1]}; do
        if [[ -z "${seen_packages[${package}]:-}" ]]; then
          seen_packages["${package}"]=1
          packages+=("${package}")
        fi
      done
    fi
  done < "${script_path}"
done

if [[ ${#packages[@]} -eq 0 ]]; then
  exit 0
fi

run_apt_update_if_stale
echo "Installing APT packages required by helper scripts: ${packages[*]}"
$SUDO env DEBIAN_FRONTEND=noninteractive apt-get install -y -- "${packages[@]}"
